    "lint": "eslint '**/*.{ts,tsx}' --fix",
    "format": "prettier --write '**/*.{ts,tsx}'",
    "export": "next export",
    "compile": "npm run build:governance && NODE_OPTIONS=--max_old_space_size=8192 next build && next export"
